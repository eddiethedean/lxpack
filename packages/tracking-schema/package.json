{
  "name": "@lxpack/tracking-schema",
  "version": "0.6.1",
  "description": "Shared tracking event schema for LXPack and adapters",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/tracking-schema"
  },
  "bugs": {
    "url": "https://github.com/eddiethedean/lxpack/issues"
  },
  "homepage": "https://github.com/eddiethedean/lxpack#readme",
  "keywords": ["lxpack", "tracking", "xapi", "scorm", "schema"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}

