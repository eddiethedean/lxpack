{
  "name": "@lxpack/cmi5",
  "version": "0.3.6",
  "description": "cmi5 packaging for LXPack courses",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/cmi5"
  },
  "bugs": {
    "url": "https://github.com/eddiethedean/lxpack/issues"
  },
  "homepage": "https://github.com/eddiethedean/lxpack#readme",
  "keywords": ["lxpack", "cmi5", "xapi", "lms", "elearning"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lxpack/validators": "workspace:*",
    "@lxpack/xapi": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
