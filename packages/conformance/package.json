{
  "name": "@lxpack/conformance",
  "version": "0.6.2",
  "description": "Shared LessonKit/LXPack export conformance fixtures and matrix runner",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/conformance"
  },
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "fixtures"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lxpack/api": "workspace:*",
    "@lxpack/scorm": "workspace:*",
    "@lxpack/validators": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
