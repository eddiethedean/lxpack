{
  "name": "@lxpack/runtime",
  "version": "0.3.7",
  "description": "Web-native course runtime for LXPack",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/eddiethedean/lxpack/issues"
  },
  "homepage": "https://github.com/eddiethedean/lxpack#readme",
  "keywords": [
    "lxpack",
    "scorm",
    "lms",
    "elearning",
    "runtime"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./client": "./dist/client.js",
    "./scorm12": {
      "types": "./dist/scorm12.d.ts",
      "import": "./dist/scorm12.js"
    },
    "./scorm2004": {
      "types": "./dist/scorm2004.d.ts",
      "import": "./dist/scorm2004.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vite build -c vite.runtime.config.ts && tsc -p tsconfig.build.json --emitDeclarationOnly && cp src/styles.css dist/styles.css",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lxpack/validators": "workspace:*",
    "@lxpack/xapi": "workspace:*",
    "dompurify": "^3.4.5",
    "marked": "^15.0.7",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "happy-dom": "^17.4.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.2",
    "vitest": "^3.1.1"
  }
}
