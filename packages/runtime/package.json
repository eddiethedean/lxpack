{
  "name": "@lxpack/runtime",
  "version": "0.1.0",
  "description": "Web-native course runtime for LXPack",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./client": "./dist/client.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lxpack/validators": "workspace:*",
    "marked": "^15.0.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "happy-dom": "^17.4.4",
    "typescript": "^5.8.3",
    "vite": "^6.2.2",
    "vitest": "^3.1.1"
  }
}
