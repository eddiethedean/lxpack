{
  "name": "@lxpack/cli",
  "version": "0.1.0",
  "description": "CLI for building, validating, and packaging LXPack courses",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "lxpack": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@lxpack/runtime": "workspace:*",
    "@lxpack/scorm": "workspace:*",
    "@lxpack/validators": "workspace:*",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
