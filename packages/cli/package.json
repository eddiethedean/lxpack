{
  "name": "@lxpack/cli",
  "version": "0.4.0",
  "description": "CLI for building, validating, and packaging LXPack courses",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/eddiethedean/lxpack/issues"
  },
  "homepage": "https://github.com/eddiethedean/lxpack#readme",
  "keywords": ["lxpack", "cli", "scorm", "lms", "elearning"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "lxpack": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@lxpack/components": "workspace:*",
    "@lxpack/api": "workspace:*",
    "@lxpack/runtime": "workspace:*",
    "@lxpack/scorm": "workspace:*",
    "@lxpack/validators": "workspace:*",
    "commander": "^13.1.0",
    "fastify": "^5.2.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "happy-dom": "^17.4.4",
    "jszip": "^3.10.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
