{
  "name": "@lxpack/lessonkit",
  "version": "0.7.0",
  "description": "LessonKit integration facade for LXPack (package, bridge, interchange)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddiethedean/lxpack.git",
    "directory": "packages/lessonkit"
  },
  "engines": { "node": ">=18" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@lxpack/api": "workspace:*",
    "@lxpack/spa-bridge": "workspace:*",
    "@lxpack/tracking-schema": "workspace:*",
    "@lxpack/validators": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
